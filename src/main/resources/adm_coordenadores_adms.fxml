<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.demo3.controller.AdmCoordenadoresAdmsController"
            stylesheets="@style.css">

    <top>
        <Label text="Coordenadores e Administradores"
               styleClass="page-title"
               style="-fx-padding: 12 16;"/>
    </top>

    <center>
        <TabPane tabClosingPolicy="UNAVAILABLE">

            <!-- ── ABA 1: COORDENADORES ── -->
            <Tab text="👤 Coordenadores">
                <SplitPane dividerPositions="0.56">

                    <!-- Tabela -->
                    <VBox spacing="10">
                        <padding><Insets top="12" right="8" bottom="12" left="14"/></padding>
                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <Label text="Coordenadores Cadastrados"
                                   style="-fx-font-weight: bold;" HBox.hgrow="ALWAYS"/>
                            <Button text="+ Novo" onAction="#handleNovoCoordenador"
                                    styleClass="btn-primary"/>
                        </HBox>
                        <TableView fx:id="tabelaCoordenadores"
                                   onMouseClicked="#handleSelecionarCoordenador"
                                   VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colCoordNome"  text="Nome"    prefWidth="160"/>
                                <TableColumn fx:id="colCoordEmail" text="E-mail"  prefWidth="190"/>
                                <TableColumn fx:id="colCoordCurso" text="Curso"   prefWidth="150"/>
                                <TableColumn fx:id="colCoordAcoes" text="Ações"   prefWidth="85"/>
                            </columns>
                            <placeholder><Label text="Nenhum coordenador cadastrado."/></placeholder>
                        </TableView>
                    </VBox>

                    <!-- Formulário -->
                    <VBox spacing="12">
                        <padding><Insets top="12" right="14" bottom="12" left="8"/></padding>
                        <Label fx:id="lblTituloFormCoord" text="Novo Coordenador"
                               style="-fx-font-weight: bold; -fx-font-size: 13px;"/>

                        <VBox spacing="4">
                            <Label text="Nome *"/>
                            <TextField fx:id="tfCoordNome" promptText="Nome completo"/>
                            <Label fx:id="errCoordNome" styleClass="error-label"
                                   visible="false" managed="false"/>
                        </VBox>
                        <VBox spacing="4">
                            <Label text="E-mail *"/>
                            <TextField fx:id="tfCoordEmail" promptText="email@inst.edu.br"/>
                            <Label fx:id="errCoordEmail" styleClass="error-label"
                                   visible="false" managed="false"/>
                        </VBox>
                        <VBox spacing="4">
                            <Label text="Senha *"/>
                            <PasswordField fx:id="pfCoordSenha" promptText="Mínimo 6 caracteres"/>
                            <Label fx:id="errCoordSenha" styleClass="error-label"
                                   visible="false" managed="false"/>
                        </VBox>
                        <VBox spacing="4">
                            <Label text="Curso *"/>
                            <ComboBox fx:id="cbCoordCurso" maxWidth="Infinity"
                                      promptText="Selecione o curso"/>
                            <Label fx:id="errCoordCurso" styleClass="error-label"
                                   visible="false" managed="false"/>
                        </VBox>

                        <HBox spacing="8" alignment="CENTER_RIGHT">
                            <Button text="Limpar" onAction="#handleLimparFormCoord"
                                    styleClass="btn-ghost"/>
                            <Button text="Salvar" onAction="#handleSalvarCoordenador"
                                    styleClass="btn-primary"/>
                        </HBox>
                        <Label fx:id="lblFeedbackCoord"
                               visible="false" managed="false" styleClass="feedback-label"/>
                    </VBox>
                </SplitPane>
            </Tab>

            <!-- ── ABA 2: ADMINISTRADORES ── -->
            <Tab text="🔐 Administradores">
                <SplitPane dividerPositions="0.56">

                    <!-- Tabela -->
                    <VBox spacing="10">
                        <padding><Insets top="12" right="8" bottom="12" left="14"/></padding>
                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <Label text="Administradores do Sistema"
                                   style="-fx-font-weight: bold;" HBox.hgrow="ALWAYS"/>
                            <Button text="+ Novo ADM" onAction="#handleNovoAdm"
                                    styleClass="btn-primary"/>
                        </HBox>
                        <TableView fx:id="tabelaAdms"
                                   onMouseClicked="#handleSelecionarAdm"
                                   VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colAdmNome"  text="Nome"   prefWidth="200"/>
                                <TableColumn fx:id="colAdmEmail" text="E-mail" prefWidth="220"/>
                                <TableColumn fx:id="colAdmAcoes" text="Ações"  prefWidth="85"/>
                            </columns>
                            <placeholder><Label text="Nenhum ADM adicional cadastrado."/></placeholder>
                        </TableView>
                    </VBox>

                    <!-- Formulário -->
                    <VBox spacing="12">
                        <padding><Insets top="12" right="14" bottom="12" left="8"/></padding>
                        <Label fx:id="lblTituloFormAdm" text="Novo Administrador"
                               style="-fx-font-weight: bold; -fx-font-size: 13px;"/>

                        <VBox spacing="4">
                            <Label text="Nome *"/>
                            <TextField fx:id="tfAdmNome" promptText="Nome completo"/>
                            <Label fx:id="errAdmNome" styleClass="error-label"
                                   visible="false" managed="false"/>
                        </VBox>
                        <VBox spacing="4">
                            <Label text="E-mail *"/>
                            <TextField fx:id="tfAdmEmail" promptText="email@inst.edu.br"/>
                            <Label fx:id="errAdmEmail" styleClass="error-label"
                                   visible="false" managed="false"/>
                        </VBox>
                        <VBox spacing="4">
                            <Label text="Senha *"/>
                            <PasswordField fx:id="pfAdmSenha" promptText="Mínimo 6 caracteres"/>
                            <Label fx:id="errAdmSenha" styleClass="error-label"
                                   visible="false" managed="false"/>
                        </VBox>

                        <HBox spacing="8" alignment="CENTER_RIGHT">
                            <Button text="Limpar" onAction="#handleLimparFormAdm"
                                    styleClass="btn-ghost"/>
                            <Button text="Salvar" onAction="#handleSalvarAdm"
                                    styleClass="btn-primary"/>
                        </HBox>
                        <Label fx:id="lblFeedbackAdm"
                               visible="false" managed="false" styleClass="feedback-label"/>
                    </VBox>

                </SplitPane>
            </Tab>

        </TabPane>
    </center>

</BorderPane>
