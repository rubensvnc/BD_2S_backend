<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TreeView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:id="BorderPane_Planejamento" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.demo3.controller.ProfPlanejamentoController">

    <top>
        <VBox spacing="6">
            <padding><Insets bottom="8" left="16" right="16" top="12" /></padding>
            <HBox alignment="CENTER_LEFT" spacing="14">
                <Label style="-fx-font-size: 16px; -fx-font-weight: bold;" text="Planejamento e Estatísticas" />
                <Region HBox.hgrow="ALWAYS" />
                <!-- ProgressIndicator visível apenas durante geração (8.3.1 / seção 12 — Loading) -->
                <ProgressIndicator fx:id="progressGeracao" managed="false" prefHeight="24" prefWidth="24" visible="false" />
                <Button fx:id="btnGerarPlanejamento" onAction="#handleGerarPlanejamento" style="-fx-background-color: #2980b9; -fx-text-fill: white; -fx-font-weight: bold;" text="⚙ Gerar / Atualizar Planejamento" />
            </HBox>
        </VBox>
    </top>

    <center>
        <TabPane tabClosingPolicy="UNAVAILABLE">

            <!-- ═══════════════════════════════════════════════════════
                 ABA 1 — PLANEJAMENTO + ESTATÍSTICAS
                 Cobre: 8.3.3 (visualização agenda), 8.3.4 (confirmação/cancelamento em lote),
                         9.1–9.3 (estatísticas em tempo real)
            ════════════════════════════════════════════════════════ -->
            <Tab text="📋 Planejamento e Estatísticas">
                <SplitPane dividerPositions="0.62">

                    <!-- ──────────────────────────────────────────────
                         ESQUERDA: Planejamento — agenda agrupada por data
                    ─────────────────────────────────────────────── -->
                    <VBox spacing="8">
                        <padding><Insets bottom="8" left="14" right="6" top="8" /></padding>

                        <!-- Barra de ações em lote (aparece ao selecionar ≥1 CheckBox) -->
                        <HBox fx:id="barraAcoesLote" alignment="CENTER_LEFT" managed="false" spacing="10" style="-fx-background-color: #dfe6e9; -fx-padding: 6 10;                                      -fx-background-radius: 4; -fx-border-radius: 4;" visible="false">
                            <Label fx:id="lblQtdSelecionados" text="0 item(ns) selecionado(s)" />
                            <Region HBox.hgrow="ALWAYS" />
                            <Button onAction="#handleMarcarMinistrada" style="-fx-background-color: #27ae60; -fx-text-fill: white;" text="✅ Marcar como Ministrada" />
                            <!-- Abre Dialog com TextArea para motivo; aplica a todos os selecionados -->
                            <Button onAction="#handleCancelarSelecionados" style="-fx-background-color: #e74c3c; -fx-text-fill: white;" text="❌ Cancelar Selecionados" />
                        </HBox>

                        <!-- TreeView: raiz invisível → nível 1 = datas → nível 2 = slots
                             Cada célula de slot possui: CheckBox + label horário +
                             label tema + indicador de status (ícone/cor)
                             Slots cancelados pela Secretaria aparecem bloqueados (sem CheckBox ativo) -->
                        <TreeView fx:id="treePlanejamento" onMouseClicked="#handleClicSlot" showRoot="false" VBox.vgrow="ALWAYS" />
                    </VBox>

                    <!-- ──────────────────────────────────────────────
                         DIREITA: Painel de Estatísticas
                    ─────────────────────────────────────────────── -->
                    <ScrollPane fitToWidth="true">
                        <VBox spacing="12">
                            <padding><Insets bottom="14" left="8" right="14" top="8" /></padding>

                            <Label style="-fx-font-weight: bold; -fx-font-size: 14px;" text="Estatísticas da Disciplina" />

                            <!-- Barra de conclusão da carga horária -->
                            <VBox spacing="4">
                                <HBox alignment="CENTER_LEFT" spacing="8">
                                    <Label style="-fx-font-weight: bold;" text="Conclusão da CH:" />
                                    <Label fx:id="lblPctConclusao" text="0 %" />
                                </HBox>
                                <ProgressBar fx:id="progressConclusao" maxWidth="Infinity" progress="0" />
                                <Label fx:id="lblAulasMinVsMin" style="-fx-font-size: 11px; -fx-text-fill: #7f8c8d;" text="0 / 0 aulas ministradas" />
                            </VBox>

                            <Separator />

                            <!-- Contadores individuais -->
                            <GridPane hgap="16" vgap="7">

                                <Label style="-fx-font-weight: bold;" text="Total de Temas:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                                <Label fx:id="lblTotalTemas" text="—" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                                <Label style="-fx-font-weight: bold;" text="Não Ministradas:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                                <Label fx:id="lblNaoMinistradas" text="—" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                                <Label style="-fx-font-weight: bold;" text="Canceladas (Professor):" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                                <Label fx:id="lblCancelProf" text="—" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                                <Label style="-fx-font-weight: bold;" text="Canceladas (Secretaria):" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                                <Label fx:id="lblCancelAdm" text="—" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                                <Label style="-fx-font-weight: bold;" text="Avaliações Restantes:" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                                <Label fx:id="lblAvalRestantes" text="—" GridPane.columnIndex="1" GridPane.rowIndex="4" />

                                <Label style="-fx-font-weight: bold;" text="Sábados Utilizados:" GridPane.columnIndex="0" GridPane.rowIndex="5" />
                                <Label fx:id="lblSabados" text="—" GridPane.columnIndex="1" GridPane.rowIndex="5" />

                                <Label style="-fx-font-weight: bold;" text="Opcionais Incluídos:" GridPane.columnIndex="0" GridPane.rowIndex="6" />
                                <Label fx:id="lblOpcionais" text="—" GridPane.columnIndex="1" GridPane.rowIndex="6" />

                                <Label style="-fx-font-weight: bold;" text="Projeção de Conclusão:" GridPane.columnIndex="0" GridPane.rowIndex="7" />
                                <Label fx:id="lblProjecao" text="—" GridPane.columnIndex="1" GridPane.rowIndex="7" />
                        <columnConstraints>
                           <ColumnConstraints />
                           <ColumnConstraints />
                        </columnConstraints>
                        <rowConstraints>
                           <RowConstraints />
                           <RowConstraints />
                           <RowConstraints />
                           <RowConstraints />
                           <RowConstraints />
                           <RowConstraints />
                           <RowConstraints />
                           <RowConstraints />
                        </rowConstraints>
                            </GridPane>

                            <Separator />

                            <!-- Gráfico de pizza: proporção de status dos slots -->
                            <Label style="-fx-font-weight: bold;" text="Distribuição de Status das Aulas" />
                            <PieChart fx:id="pieChartStatus" labelsVisible="true" legendVisible="true" prefHeight="190" />

                            <Separator />

                            <!-- Aulas alocadas por tema -->
                            <Label style="-fx-font-weight: bold;" text="Aulas por Tema" />
                            <TableView fx:id="tabelaAulasTema" prefHeight="180">
                                <columns>
                                    <TableColumn fx:id="colATNome" prefWidth="165" text="Tema" />
                                    <TableColumn fx:id="colATAlocadas" prefWidth="110" text="Aulas Alocadas" />
                                </columns>
                                <placeholder>
                                    <Label text="Planejamento ainda não gerado." />
                                </placeholder>
                            </TableView>

                        </VBox>
                    </ScrollPane>

                </SplitPane>
            </Tab>

            <!-- ═══════════════════════════════════════════════════════
                 ABA 2 — MINHA ROTINA  (cobre seção 10 — somente leitura)
                 Exibe dias/horários por disciplina + CH mínima vs. gerada
            ════════════════════════════════════════════════════════ -->
            <Tab text="🗓 Minha Rotina">
                <VBox spacing="12">
                    <padding><Insets bottom="12" left="16" right="16" top="12" /></padding>

                    <Label style="-fx-text-fill: #7f8c8d; -fx-font-size: 11px;" text="Horários e carga horária por disciplina — somente visualização." />

                    <TableView fx:id="tabelaRotina" editable="false" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colRotDisciplina" prefWidth="210" text="Disciplina" />
                            <TableColumn fx:id="colRotCHMin" prefWidth="95" text="CH Mínima" />
                        </columns>
                        <placeholder>
                            <Label text="Nenhuma atribuição ativa no contexto selecionado." />
                        </placeholder>
                    </TableView>
               <TableView fx:id="tabelaRotina1" editable="false">
                  <columns>
                     <TableColumn fx:id="colRotDia1" prefWidth="120" text="Dia da Semana" />
                     <TableColumn fx:id="colRotHorario1" prefWidth="150" text="Horário" />
                     <TableColumn fx:id="colRotAulasGeradas1" prefWidth="110" text="Aulas Geradas" />
                  </columns>
                  <placeholder>
                     <Label text="Nenhuma disciplina selecionada." />
                  </placeholder>
               </TableView>
                </VBox>
            </Tab>

        </TabPane>
    </center>

</BorderPane>
