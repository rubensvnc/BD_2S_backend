<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.control.ToolBar?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="768" prefWidth="1366" stylesheets="@style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.demo3.controller.MainShellController">

    <top>
        <VBox>
            <ToolBar>

                <Label styleClass="nav-brand" text="SwiftPlan" />

                <Separator opacity="0.25" orientation="VERTICAL" />

                <Label text="Ano:" />
                <ComboBox fx:id="cbAno" onAction="#handleTrocaAno" prefHeight="35.0" prefWidth="102.0" />

                <Separator opacity="0.0" orientation="VERTICAL" />

                <Label text="Semestre:" />
                <ToggleButton fx:id="tbSem1" onAction="#handleSemestreToggle" text="1º" />
                <ToggleButton fx:id="tbSem2" onAction="#handleSemestreToggle" text="2º" />

                <Separator opacity="0.0" orientation="VERTICAL" />

                <Label fx:id="lblCurso" text="Curso:" />
                <ComboBox fx:id="cbCurso" onAction="#handleTrocaCurso" prefWidth="200" />

                <Separator opacity="0.0" orientation="VERTICAL" />

                <Label fx:id="lblSemestreCurso" text="Sem. do Curso:" />
                <ComboBox fx:id="cbSemestreCurso" onAction="#handleTrocaSemestreCurso" prefWidth="80" />

                <Separator opacity="0.0" orientation="VERTICAL" />

                <Label fx:id="lblDisciplina" text="Disciplina:" />
                <ComboBox fx:id="cbDisciplina" onAction="#handleTrocaDisciplina" prefWidth="120" />

                <Separator opacity="0.0" orientation="VERTICAL" />

                <Region HBox.hgrow="ALWAYS" />

                <VBox alignment="CENTER_RIGHT" spacing="1">
                    <Label fx:id="lblNomeUsuario" styleClass="user-name" />
                    <Label fx:id="lblPerfilUsuario" styleClass="user-role" />
                </VBox>

                <Separator opacity="0.0" orientation="VERTICAL" />
                <Button onAction="#handleLogout" text="Sair" />
            </ToolBar>

            <Label fx:id="bannerReadOnly" managed="false" maxWidth="Infinity" styleClass="banner-readonly" text="⚠   Você está visualizando um período passado — modo somente leitura" textAlignment="CENTER" visible="false" />
        </VBox>
    </top>

    <left>
        <VBox fx:id="menuLateral" prefWidth="210" spacing="2" styleClass="sidebar">
            <padding><Insets bottom="14" left="8" right="8" top="14" /></padding>

            <VBox fx:id="secaoAdm" managed="false" spacing="2" visible="false">
                <Label styleClass="sidebar-group-label" text="ADMINISTRADOR" />
                <Button maxWidth="Infinity" onAction="#navCalendario" styleClass="menu-item" text="📅  Calendário Acadêmico" />
                <Button maxWidth="Infinity" onAction="#navCursosHorarios" styleClass="menu-item" text="🏫  Cursos e Horários" />
                <Button maxWidth="Infinity" onAction="#navCoordenaodresAdms" styleClass="menu-item" text="👥  Coordenadores / ADMs" />
                <Button maxWidth="Infinity" onAction="#navBloqueios" styleClass="menu-item" text="🚫  Bloqueios e Cancelamentos" />
            </VBox>

            <VBox fx:id="secaoCoordenador" managed="false" spacing="2" visible="false">
                <Label styleClass="sidebar-group-label" text="COORDENADOR" />
                <Button maxWidth="Infinity" onAction="#navCoordPainel" styleClass="menu-item" text="📚  Disciplinas e Professores" />
            </VBox>

            <VBox fx:id="secaoProfessor" managed="false" spacing="2" visible="false">
                <Label styleClass="sidebar-group-label" text="PROFESSOR" />
                <Button maxWidth="Infinity" onAction="#navTemas" styleClass="menu-item" text="📝  Temas" />
                <Button maxWidth="Infinity" onAction="#navPlanejamento" styleClass="menu-item" text="📋  Planejamento e Estatísticas" />
            </VBox>
        </VBox>
    </left>

    <center>
        <StackPane fx:id="areaConteudo" styleClass="content-area">
            <Label style="-fx-font-size: 14px;" styleClass="text-muted" text="Selecione uma seção no menu lateral." />
        </StackPane>
    </center>

</BorderPane>
