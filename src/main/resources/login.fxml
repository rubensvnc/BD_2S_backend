<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="org.example.demo3.controller.LoginController"
           stylesheets="@style.css"
           prefWidth="480" prefHeight="420">

    <!-- PAINEL DE LOGIN (padrão) -->
    <VBox fx:id="loginPane" alignment="CENTER" spacing="16" maxWidth="360">
        <padding><Insets top="40" right="40" bottom="40" left="40"/></padding>

        <Label text="SwiftPlan" styleClass="nav-brand" style="-fx-font-size: 28px;"/>
        <Label text="Sistema de Gestão e Planejamento Acadêmico"
               styleClass="text-muted" wrapText="true" style="-fx-font-size: 12px;"/>

        <VBox spacing="4">
            <Label text="E-mail"/>
            <TextField fx:id="loginEmail" promptText="seu@email.com"/>
            <Label fx:id="errLoginEmail" styleClass="error-label" visible="false" managed="false"/>
        </VBox>

        <VBox spacing="4">
            <Label text="Senha"/>
            <PasswordField fx:id="loginSenha" promptText="Sua senha"/>
            <Label fx:id="errLoginSenha" styleClass="error-label" visible="false" managed="false"/>
        </VBox>

        <Label fx:id="errLoginGeral" styleClass="error-label" visible="false" managed="false"/>

        <Button fx:id="btnLogin" text="Entrar" onAction="#handleLogin"
                maxWidth="Infinity" defaultButton="true"
                styleClass="btn-primary"/>
    </VBox>

    <!-- PAINEL DE PRIMEIRO ACESSO -->
    <VBox fx:id="primeiroAcessoPane" alignment="CENTER" spacing="16" maxWidth="360"
          visible="false" managed="false">
        <padding><Insets top="40" right="40" bottom="40" left="40"/></padding>

        <Label text="Primeiro Acesso" style="-fx-font-size: 22px; -fx-font-weight: bold;"/>
        <Label text="Nenhum administrador encontrado. Cadastre o primeiro ADM para continuar."
               wrapText="true" styleClass="text-muted"/>

        <VBox spacing="4">
            <Label text="Nome *"/>
            <TextField fx:id="admNome" promptText="Nome completo"/>
            <Label fx:id="errAdmNome" styleClass="error-label" visible="false" managed="false"/>
        </VBox>

        <VBox spacing="4">
            <Label text="E-mail *"/>
            <TextField fx:id="admEmail" promptText="email@instituicao.edu.br"/>
            <Label fx:id="errAdmEmail" styleClass="error-label" visible="false" managed="false"/>
        </VBox>

        <VBox spacing="4">
            <Label text="Senha *"/>
            <PasswordField fx:id="admSenha" promptText="Mínimo 6 caracteres"/>
            <Label fx:id="errAdmSenha" styleClass="error-label" visible="false" managed="false"/>
        </VBox>

        <Button text="Cadastrar Administrador" onAction="#handleCadastrarPrimeiroAdm"
                maxWidth="Infinity" defaultButton="true"
                styleClass="btn-primary"/>

        <Label fx:id="feedbackPrimeiroAcesso" visible="false" managed="false" styleClass="feedback-label"/>
    </VBox>

</StackPane>
